{
  "name": "@perry-fixtures/native-memory-fixture",
  "version": "0.1.0",
  "main": "index.ts",
  "types": "index.ts",
  "perry": {
    "nativeLibrary": {
      "module": "@perry-fixtures/native-memory-fixture",
      "abiVersion": "0.5",
      "functions": [
        {
          "name": "native_memory_fixture_sum",
          "params": [
            {
              "kind": "pod+count",
              "name": "NativeMemoryFixturePacket",
              "fields": [
                { "name": "tag", "type": "u32" },
                { "name": "count", "type": "u32" },
                { "name": "checksum", "type": "u32" },
                { "name": "reserved", "type": "u32" }
              ]
            }
          ],
          "returns": "u32"
        }
      ],
      "targets": {
        "macos": { "crate": "native", "lib": "native_memory_fixture" },
        "linux": { "crate": "native", "lib": "native_memory_fixture" }
      }
    }
  }
}
